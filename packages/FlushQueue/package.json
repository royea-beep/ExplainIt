{
  "name": "@royea/flush-queue",
  "version": "1.0.0",
  "description": "Client-side event buffer — queue events, batch POST to a configurable URL, with retry and optional offline persist.",
  "author": "Roy Arguan <royearguan@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "typesVersions": {
    "*": {
      ".": ["./src/index.ts"]
    }
  },
  "files": ["src", "README.md"],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["event-queue", "batch", "flush", "analytics", "offline", "buffer"],
  "repository": {
    "type": "git",
    "url": "https://github.com/royea-beep/flush-queue"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  }
}
