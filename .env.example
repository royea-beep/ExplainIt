# ExplainIt Configuration
# Copy to .env.local for development

# Base URL for the app (used for OG tags, WhatsApp share links, absolute URLs)
# Development: http://localhost:3000
# Production (Vercel): https://explainit-one.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# JWT secret for auth (generate with: openssl rand -hex 32)
JWT_SECRET=

# Playwright browser path (optional — uses bundled Chromium by default)
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

# Max concurrent pipelines (default: 10)
# MAX_PIPELINES=10

# Export directory (default: ./exports)
# EXPORTS_DIR=./exports

# LemonSqueezy billing (see LEMONSQUEEZY_SETUP.md)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=309460
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_PRO_VARIANT_ID=
LEMONSQUEEZY_TEAM_VARIANT_ID=
